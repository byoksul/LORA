# Production ortam değişkenleri — docker-compose.prod.yml için
# Kopyalayın: cp docker/.env.prod.example docker/.env.prod
# Kullanım: docker compose -f docker-compose.prod.yml --env-file docker/.env.prod up --build

# PostgreSQL
POSTGRES_USER=loracoffee
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=loracoffee

# JWT (en az 32 karakter)
JWT_KEY=change-me-production-jwt-secret-min-32-chars
JWT_ISSUER=LoraCoffee.API
JWT_AUDIENCE=LoraCoffee.Client

# CORS (virgülle ayrılmış origin listesi)
CORS_ORIGINS=https://yourdomain.com

# Frontend build — production'da boş bırakın (nginx proxy kullanır)
VITE_API_URL=
VITE_HUB_URL=

# Portlar
HTTP_PORT=80
HTTPS_PORT=443
