# LORA Coffee OS — Frontend Environment Variables

# --- Local dev (Vite proxy, önerilen) ---
# API ve SignalR istekleri Vite üzerinden http://localhost:5000'e yönlendirilir.
VITE_API_URL=
VITE_HUB_URL=

# --- Doğrudan API bağlantısı (proxy olmadan) ---
# VITE_API_URL=http://localhost:5000
# VITE_HUB_URL=http://localhost:5000/hubs/orders

